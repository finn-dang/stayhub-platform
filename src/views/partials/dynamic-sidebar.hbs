{{!-- Dynamic Sidebar based on User Role --}}
<aside class="dynamic-sidebar" data-role="{{userRole}}">
    <div class="sidebar-header" style="background: {{roleGradient}}">
        <div class="sidebar-welcome">
            <i class="bi {{roleIcon}}"></i>
            <div>
                <span>Xin chào,</span>
                <strong>{{user_name}}</strong>
            </div>
        </div>
        <div class="sidebar-role-badge">
            {{roleName}}
        </div>
    </div>

    <nav class="sidebar-nav">
        <!-- Main Navigation -->
        <div class="nav-section">
            <div class="nav-section-title">MENU CHÍNH</div>
            {{#each mainNavItems}}
                <a href="{{this.href}}" class="nav-item {{#if this.active}}active{{/if}}" data-tooltip="{{this.label}}">
                    <i class="bi {{this.icon}}"></i>
                    <span>{{this.label}}</span>
                    {{#if this.badge}}
                        <span class="nav-badge">{{this.badge}}</span>
                    {{/if}}
                </a>
            {{/each}}
        </div>

        <!-- Quick Stats for Host -->
        {{#eq userRole 'host'}}
            <div class="stats-section">
                <div class="stat-card">
                    <i class="bi bi-building"></i>
                    <div>
                        <span class="stat-value">{{totalRooms}}</span>
                        <span class="stat-label">Bài đăng</span>
                    </div>
                </div>
                <div class="stat-card">
                    <i class="bi bi-calendar-check"></i>
                    <div>
                        <span class="stat-value">{{totalBookings}}</span>
                        <span class="stat-label">Đặt phòng</span>
                    </div>
                </div>
                <div class="stat-card">
                    <i class="bi bi-wallet2"></i>
                    <div>
                        <span class="stat-value">{{formatCurrency totalEarnings}}</span>
                        <span class="stat-label">Doanh thu</span>
                    </div>
                </div>
            </div>
        {{/eq}}

        <!-- Quick Stats for Admin -->
        {{#eq userRole 'admin'}}
            <div class="stats-section">
                <div class="stat-card">
                    <i class="bi bi-people"></i>
                    <div>
                        <span class="stat-value">{{totalUsers}}</span>
                        <span class="stat-label">Người dùng</span>
                    </div>
                </div>
                <div class="stat-card">
                    <i class="bi bi-building"></i>
                    <div>
                        <span class="stat-value">{{totalRooms}}</span>
                        <span class="stat-label">Bài đăng</span>
                    </div>
                </div>
                <div class="stat-card">
                    <i class="bi bi-flag"></i>
                    <div>
                        <span class="stat-value">{{totalReports}}</span>
                        <span class="stat-label">Báo cáo</span>
                    </div>
                </div>
                <div class="stat-card">
                    <i class="bi bi-cash-stack"></i>
                    <div>
                        <span class="stat-value">{{formatCurrency totalRevenue}}</span>
                        <span class="stat-label">Doanh thu</span>
                    </div>
                </div>
            </div>
        {{/eq}}

        <!-- Secondary Navigation -->
        <div class="nav-section">
            <div class="nav-section-title">TIỆN ÍCH</div>
            {{#each secondaryNavItems}}
                <a href="{{this.href}}" class="nav-item">
                    <i class="bi {{this.icon}}"></i>
                    <span>{{this.label}}</span>
                </a>
            {{/each}}
        </div>
    </nav>

    <!-- Sidebar Footer -->
    <div class="sidebar-footer">
        <div class="sidebar-version">
            <i class="bi bi-info-circle"></i>
            <span>Version 2.0.0</span>
        </div>
    </div>
</aside>

<style>
.dynamic-sidebar {
    width: 280px;
    height: 100vh;
    background: white;
    border-right: 1px solid #EEE;
    position: sticky;
    top: 0;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
}

.sidebar-header {
    padding: 1.5rem;
    color: white;
}

.sidebar-welcome {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
}

.sidebar-welcome i {
    font-size: 1.5rem;
}

.sidebar-welcome div {
    display: flex;
    flex-direction: column;
}

.sidebar-welcome span {
    font-size: 0.75rem;
    opacity: 0.8;
}

.sidebar-welcome strong {
    font-size: 1rem;
}

.sidebar-role-badge {
    background: rgba(255,255,255,0.2);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    display: inline-block;
}

/* Navigation */
.sidebar-nav {
    flex: 1;
    padding: 1.5rem 1rem;
}

.nav-section {
    margin-bottom: 2rem;
}

.nav-section-title {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #8A8A8A;
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
}

.nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    color: #484848;
    transition: all 0.3s;
    margin-bottom: 0.25rem;
    position: relative;
}

.nav-item i {
    width: 1.25rem;
    font-size: 1.1rem;
}

.nav-item:hover {
    background: #F7F7F7;
    color: #FF385C;
}

.nav-item.active {
    background: linear-gradient(135deg, #FFF5F5, #FFE5E5);
    color: #FF385C;
    font-weight: 500;
}

.nav-badge {
    margin-left: auto;
    background: #FF385C;
    color: white;
    font-size: 0.7rem;
    padding: 0.125rem 0.5rem;
    border-radius: 1rem;
}

/* Stats Section */
.stats-section {
    background: #F7F7F7;
    border-radius: 1rem;
    padding: 1rem;
    margin-bottom: 2rem;
}

.stat-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    background: white;
    border-radius: 0.75rem;
    margin-bottom: 0.5rem;
}

.stat-card:last-child {
    margin-bottom: 0;
}

.stat-card i {
    font-size: 1.5rem;
    color: #FF385C;
}

.stat-card div {
    display: flex;
    flex-direction: column;
}

.stat-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: #222;
}

.stat-label {
    font-size: 0.7rem;
    color: #8A8A8A;
}

/* Sidebar Footer */
.sidebar-footer {
    padding: 1rem;
    border-top: 1px solid #EEE;
}

.sidebar-version {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    color: #8A8A8A;
}

/* Scrollbar */
.dynamic-sidebar::-webkit-scrollbar {
    width: 4px;
}

.dynamic-sidebar::-webkit-scrollbar-track {
    background: #F1F1F1;
}

.dynamic-sidebar::-webkit-scrollbar-thumb {
    background: #DDD;
    border-radius: 4px;
}

/* Responsive */
@media (max-width: 768px) {
    .dynamic-sidebar {
        position: fixed;
        left: -280px;
        z-index: 1050;
        transition: left 0.3s;
    }
    
    .dynamic-sidebar.mobile-open {
        left: 0;
    }
}
</style>