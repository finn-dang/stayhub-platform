{{!-- src/views/partials/header.hbs --}}
<header class="site-header">
  <div class="header-container">
    <!-- Logo -->
    <a href="/" class="logo">
      <i class="bi bi-house-heart-fill"></i>
      <span>HostHub</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav">
      <a href="/" class="nav-link">Home</a>
      <a href="/houses" class="nav-link">Explore</a>
      <a href="/host/rooms/create" class="nav-link host-link">Host your space</a>
      
      {{#if isLoggedIn}}
        {{#if (or (eq user_role "host") (eq user_role "admin"))}}
          <a href="/dashboard" class="nav-link dashboard-link">Dashboard</a>
        {{/if}}
      {{/if}}
    </nav>

    <!-- User Menu / Auth Buttons -->
    <div class="header-right">
      {{#if isLoggedIn}}
        <div class="user-menu" id="userMenu">
          <button class="user-menu-trigger" aria-label="User menu">
            {{#if user_avatar}}
              <img src="{{user_avatar}}" alt="{{user_name}}" class="user-avatar">
            {{else}}
              <div class="user-avatar default-avatar">
                <i class="bi bi-person-fill"></i>
              </div>
            {{/if}}
            <span class="user-name">{{user_name}}</span>
            <i class="bi bi-chevron-down"></i>
          </button>
          
          <div class="dropdown-menu" id="dropdownMenu">
            <a href="/profile" class="dropdown-item">
              <i class="bi bi-person"></i> Profile
            </a>
            <a href="/bookings" class="dropdown-item">
              <i class="bi bi-calendar-check"></i> My Bookings
            </a>
            <a href="/wishlist" class="dropdown-item">
              <i class="bi bi-heart"></i> Wishlist
            </a>
            <a href="/settings" class="dropdown-item">
              <i class="bi bi-gear"></i> Settings
            </a>
            <div class="dropdown-divider"></div>
            <a href="/logout" class="dropdown-item logout-item">
              <i class="bi bi-box-arrow-right"></i> Logout
            </a>
          </div>
        </div>
      {{else}}
        <div class="auth-buttons">
          <a href="/login" class="btn btn-outline">Login</a>
          <a href="/signup" class="btn btn-primary">Sign up</a>
        </div>
      {{/if}}

      <!-- Mobile Hamburger Button -->
      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Menu">
        <i class="bi bi-list"></i>
      </button>
    </div>
  </div>

  <!-- Mobile Sidebar -->
  <div class="mobile-sidebar" id="mobileSidebar">
    <div class="sidebar-header">
      <a href="/" class="logo">
        <i class="bi bi-house-heart-fill"></i>
        <span>HostHub</span>
      </a>
      <button class="sidebar-close" id="sidebarClose">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>
    
    <div class="sidebar-content">
      {{#if isLoggedIn}}
        <div class="sidebar-user">
          {{#if user_avatar}}
            <img src="{{user_avatar}}" alt="{{user_name}}" class="sidebar-avatar">
          {{else}}
            <div class="sidebar-avatar default-avatar">
              <i class="bi bi-person-fill"></i>
            </div>
          {{/if}}
          <div class="sidebar-user-info">
            <div class="sidebar-user-name">{{user_name}}</div>
            <div class="sidebar-user-role">{{user_role}}</div>
          </div>
        </div>
      {{/if}}
      
      <nav class="sidebar-nav">
        <a href="/" class="sidebar-link">
          <i class="bi bi-house"></i> Home
        </a>
        <a href="/houses" class="sidebar-link">
          <i class="bi bi-compass"></i> Explore
        </a>
        <a href="/host/rooms/create" class="sidebar-link">
          <i class="bi bi-plus-circle"></i> Host your space
        </a>
        
        {{#if isLoggedIn}}
          {{#if (or (eq user_role "host") (eq user_role "admin"))}}
            <a href="/dashboard" class="sidebar-link">
              <i class="bi bi-speedometer2"></i> Dashboard
            </a>
          {{/if}}
          <div class="sidebar-divider"></div>
          <a href="/profile" class="sidebar-link">
            <i class="bi bi-person"></i> Profile
          </a>
          <a href="/bookings" class="sidebar-link">
            <i class="bi bi-calendar-check"></i> My Bookings
          </a>
          <a href="/wishlist" class="sidebar-link">
            <i class="bi bi-heart"></i> Wishlist
          </a>
          <a href="/settings" class="sidebar-link">
            <i class="bi bi-gear"></i> Settings
          </a>
          <div class="sidebar-divider"></div>
          <a href="/logout" class="sidebar-link logout">
            <i class="bi bi-box-arrow-right"></i> Logout
          </a>
        {{else}}
          <div class="sidebar-auth">
            <a href="/login" class="btn btn-outline full-width">Login</a>
            <a href="/signup" class="btn btn-primary full-width">Sign up</a>
          </div>
        {{/if}}
      </nav>
    </div>
  </div>
  
  <!-- Sidebar Overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
</header>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .site-header {
    background: white;
    border-bottom: 1px solid #eaeaea;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .header-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 700;
    color: #FF385C;
    transition: opacity 0.3s ease;
  }

  .logo i {
    font-size: 1.75rem;
  }

  .logo span {
    background: linear-gradient(135deg, #FF385C, #E31C5F);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .logo:hover {
    opacity: 0.8;
  }

  /* Desktop Navigation */
  .desktop-nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    text-decoration: none;
    color: #222222;
    font-weight: 500;
    transition: color 0.3s ease;
    position: relative;
  }

  .nav-link:hover {
    color: #FF385C;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: #FF385C;
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .host-link {
    background: #FF385C;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 40px;
  }

  .host-link:hover {
    background: #E31C5F;
    color: white;
  }

  .host-link::after {
    display: none;
  }

  .dashboard-link {
    background: #222222;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 40px;
  }

  .dashboard-link:hover {
    background: #FF385C;
    color: white;
  }

  .dashboard-link::after {
    display: none;
  }

  /* Header Right */
  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Auth Buttons */
  .auth-buttons {
    display: flex;
    gap: 0.75rem;
  }

  .btn {
    padding: 0.5rem 1.25rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
    font-family: inherit;
  }

  .btn-primary {
    background: #FF385C;
    color: white;
  }

  .btn-primary:hover {
    background: #E31C5F;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(255, 56, 92, 0.3);
  }

  .btn-outline {
    background: transparent;
    color: #222222;
    border: 1px solid #dddddd;
  }

  .btn-outline:hover {
    border-color: #222222;
    background: #f7f7f7;
  }

  /* User Menu */
  .user-menu {
    position: relative;
  }

  .user-menu-trigger {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: white;
    border: 1px solid #dddddd;
    border-radius: 40px;
    padding: 0.25rem 0.75rem 0.25rem 0.25rem;
    cursor: pointer;
    transition: box-shadow 0.3s ease;
  }

  .user-menu-trigger:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }

  .user-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
  }

  .default-avatar {
    background: #FF385C;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .default-avatar i {
    font-size: 1rem;
  }

  .user-name {
    font-weight: 500;
    color: #222222;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    min-width: 220px;
    padding: 0.5rem 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    z-index: 100;
  }

  .dropdown-menu.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    text-decoration: none;
    color: #222222;
    transition: background 0.3s ease;
  }

  .dropdown-item i {
    width: 20px;
    color: #717171;
  }

  .dropdown-item:hover {
    background: #f7f7f7;
  }

  .dropdown-divider {
    height: 1px;
    background: #eaeaea;
    margin: 0.5rem 0;
  }

  .logout-item {
    color: #FF385C;
  }

  .logout-item i {
    color: #FF385C;
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    font-size: 1.75rem;
    cursor: pointer;
    color: #222222;
    padding: 0.5rem;
    border-radius: 50%;
    transition: background 0.3s ease;
  }

  .mobile-menu-btn:hover {
    background: #f7f7f7;
  }

  /* Mobile Sidebar */
  .mobile-sidebar {
    position: fixed;
    top: 0;
    right: -100%;
    width: 85%;
    max-width: 400px;
    height: 100%;
    background: white;
    z-index: 2000;
    transition: right 0.3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: -2px 0 20px rgba(0, 0, 0, 0.1);
  }

  .mobile-sidebar.open {
    right: 0;
  }

  .sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .sidebar-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem;
    border-bottom: 1px solid #eaeaea;
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    transition: background 0.3s ease;
  }

  .sidebar-close:hover {
    background: #f7f7f7;
  }

  .sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem;
  }

  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid #eaeaea;
  }

  .sidebar-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }

  .sidebar-user-name {
    font-weight: 600;
    font-size: 1.125rem;
    color: #222222;
  }

  .sidebar-user-role {
    font-size: 0.875rem;
    color: #717171;
    text-transform: capitalize;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    text-decoration: none;
    color: #222222;
    border-radius: 12px;
    transition: background 0.3s ease;
  }

  .sidebar-link i {
    width: 24px;
    font-size: 1.25rem;
    color: #717171;
  }

  .sidebar-link:hover {
    background: #f7f7f7;
  }

  .sidebar-link.logout {
    color: #FF385C;
  }

  .sidebar-link.logout i {
    color: #FF385C;
  }

  .sidebar-divider {
    height: 1px;
    background: #eaeaea;
    margin: 0.75rem 0;
  }

  .sidebar-auth {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .full-width {
    width: 100%;
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }

    .mobile-menu-btn {
      display: block;
    }

    .user-name {
      display: none;
    }

    .user-menu-trigger {
      padding: 0.25rem;
    }

    .header-container {
      padding: 0.5rem 1rem;
    }
  }

  @media (max-width: 576px) {
    .auth-buttons .btn {
      padding: 0.375rem 1rem;
      font-size: 0.875rem;
    }
  }
</style>

<script>
  (function() {
    // User Menu Dropdown
    const userMenuTrigger = document.getElementById('userMenu');
    const dropdownMenu = document.getElementById('dropdownMenu');
    
    if (userMenuTrigger && dropdownMenu) {
      userMenuTrigger.addEventListener('click', function(e) {
        e.stopPropagation();
        dropdownMenu.classList.toggle('show');
      });
      
      document.addEventListener('click', function() {
        dropdownMenu.classList.remove('show');
      });
      
      dropdownMenu.addEventListener('click', function(e) {
        e.stopPropagation();
      });
    }
    
    // Mobile Sidebar
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileSidebar = document.getElementById('mobileSidebar');
    const sidebarOverlay = document.getElementById('sidebarOverlay');
    const sidebarClose = document.getElementById('sidebarClose');
    
    function openSidebar() {
      if (mobileSidebar) mobileSidebar.classList.add('open');
      if (sidebarOverlay) sidebarOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    
    function closeSidebar() {
      if (mobileSidebar) mobileSidebar.classList.remove('open');
      if (sidebarOverlay) sidebarOverlay.classList.remove('open');
      document.body.style.overflow = '';
    }
    
    if (mobileMenuBtn) {
      mobileMenuBtn.addEventListener('click', openSidebar);
    }
    
    if (sidebarClose) {
      sidebarClose.addEventListener('click', closeSidebar);
    }
    
    if (sidebarOverlay) {
      sidebarOverlay.addEventListener('click', closeSidebar);
    }
  })();
</script>