<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý nhà - Host Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            overflow: hidden;
        }

        /* Main Container */
        .dashboard-container {
            width: 100%;
            height: 100vh;
            padding: 20px;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        }

        /* Main Row */
        .dashboard-main {
            width: 100%;
            height: calc(100vh - 40px);
            display: flex;
            flex-direction: row;
            gap: 20px;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            backdrop-filter: blur(10px);
        }

        /* Left Panel - House List */
        .house-list-panel {
            width: 35%;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            display: flex;
            flex-direction: column;
            border-radius: 0 20px 20px 0;
            box-shadow: 4px 0 15px rgba(0, 0, 0, 0.05);
        }

        /* Header Section */
        .panel-header {
            padding: 30px 25px 20px 25px;
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            border-bottom: 2px solid rgba(0, 0, 0, 0.05);
        }

        .panel-header h2 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 5px;
        }

        .panel-header p {
            color: #6c757d;
            font-size: 0.9rem;
            margin-bottom: 20px;
        }

        .btn-add-house {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            padding: 12px 25px;
            border-radius: 50px;
            font-weight: 600;
            color: white;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
            width: 100%;
        }

        .btn-add-house:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
            color: white;
        }

        .btn-add-house i {
            margin-right: 8px;
        }

        /* House List */
        .house-list {
            flex: 1;
            padding: 20px 25px;
            overflow-y: auto;
        }

        .house-list::-webkit-scrollbar {
            width: 6px;
        }

        .house-list::-webkit-scrollbar-track {
            background: #e9ecef;
            border-radius: 10px;
        }

        .house-list::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 10px;
        }

        .house-item {
            background: white;
            border-radius: 15px;
            margin-bottom: 15px;
            padding: 15px 20px;
            transition: all 0.3s ease;
            cursor: pointer;
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.02);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .house-item:hover {
            transform: translateX(5px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.15);
            border-color: #667eea;
        }

        .house-icon {
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #667eea;
        }

        .house-info {
            flex: 1;
        }

        .house-name {
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 5px;
            font-size: 1rem;
        }

        .house-address {
            font-size: 0.8rem;
            color: #718096;
        }

        .house-arrow {
            color: #cbd5e0;
            transition: all 0.3s ease;
        }

        .house-item:hover .house-arrow {
            transform: translateX(5px);
            color: #667eea;
        }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
            background: white;
            border-radius: 20px;
        }

        .empty-state i {
            font-size: 4rem;
            color: #cbd5e0;
            margin-bottom: 15px;
        }

        .empty-state p {
            color: #718096;
            margin-bottom: 0;
        }

        /* Right Panel - Carousel */
        .carousel-panel {
            width: 65%;
            background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
            padding: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .carousel-container {
            width: 100%;
            height: 100%;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .carousel {
            height: 100%;
        }

        .carousel-inner {
            height: 100%;
        }

        .carousel-item {
            height: 100%;
        }

        .carousel-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .carousel-caption {
            background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 100%);
            border-radius: 15px;
            padding: 20px;
            bottom: 30px;
        }

        .carousel-caption h5 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .carousel-caption p {
            font-size: 0.9rem;
            margin-bottom: 0;
            opacity: 0.9;
        }

        .carousel-indicators button {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin: 0 5px;
        }

        .carousel-control-prev,
        .carousel-control-next {
            width: 50px;
            height: 50px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            top: 50%;
            transform: translateY(-50%);
            margin: 0 20px;
        }

        .empty-carousel {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
            border-radius: 20px;
            text-align: center;
            color: white;
        }

        .empty-carousel i {
            font-size: 5rem;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .empty-carousel h4 {
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        .empty-carousel p {
            opacity: 0.7;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .dashboard-main {
                flex-direction: column;
            }
            
            .house-list-panel,
            .carousel-panel {
                width: 100%;
            }
            
            .carousel-panel {
                min-height: 400px;
            }
        }

        /* Animations */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .house-item {
            animation: fadeIn 0.5s ease forwards;
        }

        .house-item:nth-child(1) { animation-delay: 0.05s; }
        .house-item:nth-child(2) { animation-delay: 0.1s; }
        .house-item:nth-child(3) { animation-delay: 0.15s; }
        .house-item:nth-child(4) { animation-delay: 0.2s; }
        .house-item:nth-child(5) { animation-delay: 0.25s; }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <div class="dashboard-main">
            <!-- Left Panel - House List -->
            <div class="house-list-panel">
                <div class="panel-header">
                    <h2><i class="bi bi-building me-2"></i>Quản lý nhà</h2>
                    <p>Quản lý tất cả các căn nhà của bạn</p>
                    <a class="btn btn-add-house" href="/rooms/detail">
                        <i class="bi bi-plus-circle"></i> Thêm nhà mới
                    </a>
                </div>
                
                <div class="house-list">
                    {{#each user_house_list}}
                    <a class="house-item" href="/rooms/edit/{{this._id}}">
                        <div class="house-icon">
                            <i class="bi bi-house-door-fill"></i>
                        </div>
                        <div class="house-info">
                            <div class="house-name">{{this.name}}</div>
                            <div class="house-address">
                                <i class="bi bi-geo-alt-fill me-1"></i>{{this.address}}
                            </div>
                        </div>
                        <div class="house-arrow">
                            <i class="bi bi-chevron-right"></i>
                        </div>
                    </a>
                    {{else}}
                    <div class="empty-state">
                        <i class="bi bi-building"></i>
                        <p>Bạn chưa có nhà nào</p>
                        <p class="small">Hãy thêm nhà mới để bắt đầu</p>
                    </div>
                    {{/each}}
                </div>
            </div>

            <!-- Right Panel - Carousel -->
            <div class="carousel-panel">
                {{#if user_house_list.length}}
                <div class="carousel-container">
                    <div id="houseCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-indicators">
                            {{#each user_house_list}}
                            <button type="button" data-bs-target="#houseCarousel" data-bs-slide-to="{{@index}}" 
                                class="{{#if @first}}active{{/if}}" aria-current="{{#if @first}}true{{/if}}"></button>
                            {{/each}}
                        </div>
                        <div class="carousel-inner">
                            {{#each user_house_list}}
                            <div class="carousel-item {{#if @first}}active{{/if}}">
                                {{#if this.images.[0]}}
                                <img src="{{this.images.[0]}}" alt="{{this.name}}">
                                {{else}}
                                <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center;">
                                    <i class="bi bi-image" style="font-size: 5rem; color: rgba(255,255,255,0.5);"></i>
                                </div>
                                {{/if}}
                                <div class="carousel-caption">
                                    <h5><i class="bi bi-house-door-fill me-2"></i>{{this.name}}</h5>
                                    <p><i class="bi bi-geo-alt-fill me-2"></i>{{this.address}}</p>
                                </div>
                            </div>
                            {{/each}}
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#houseCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#houseCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                </div>
                {{else}}
                <div class="empty-carousel">
                    <div>
                        <i class="bi bi-images"></i>
                        <h4>Chưa có hình ảnh</h4>
                        <p>Thêm nhà mới để xem hình ảnh tại đây</p>
                    </div>
                </div>
                {{/if}}
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Initialize Bootstrap 5 carousel with auto-slide
        document.addEventListener('DOMContentLoaded', function() {
            var carouselElement = document.querySelector('#houseCarousel');
            if (carouselElement) {
                new bootstrap.Carousel(carouselElement, {
                    interval: 4000,
                    ride: 'carousel',
                    wrap: true
                });
            }
        });
    </script>
</body>
</html>