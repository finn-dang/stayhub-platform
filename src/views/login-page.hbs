<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Đăng Nhập | Hệ Thống</title>
    <!-- Bootstrap 5 CSS (latest) + Icons + Google Fonts for enhanced typography -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Google Fonts: Poppins & Inter for modern look -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
    <!-- jQuery (required for toast functionality as per original script) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <!-- Bootstrap JS Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        /* Premium gradient background + animated subtle shift */
        .loginPage {
            position: relative;
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
            background-size: 200% 200%;
            animation: gradientFlow 12s ease infinite;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(2px);
        }

        @keyframes gradientFlow {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Modern card container with glassmorphism effect */
        .glass-card {
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(0px);
            border-radius: 2rem !important;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(255, 255, 255, 0.2) inset;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            width: 100%;
            max-width: 460px;
            padding: 0.5rem 0.2rem;
        }

        .glass-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 50px rgba(0, 0, 0, 0.25);
        }

        /* form inner spacing */
        .form-container {
            padding: 1.8rem 2rem 2rem 2rem;
        }

        /* heading with elegant underline */
        .login-header h1 {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            background: linear-gradient(120deg, #2c3e66, #5a3e8f);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            font-size: 2.1rem;
            letter-spacing: -0.3px;
            margin-bottom: 0.25rem;
        }

        .login-header .sub {
            font-size: 0.85rem;
            color: #6c757d;
            font-weight: 400;
        }

        hr.gradient-hr {
            height: 3px;
            background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
            border: none;
            width: 70px;
            margin: 0.7rem auto 1.5rem auto;
            border-radius: 3px;
            opacity: 0.8;
        }

        /* Modern floating input styling (enhance) */
        .form-floating-modern {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .form-floating-modern .form-control {
            border: 1.5px solid #e2e8f0;
            border-radius: 18px;
            padding: 1rem 1rem 0.75rem 1.2rem;
            height: 58px;
            font-size: 1rem;
            background-color: #fefefe;
            transition: all 0.25s ease;
            font-weight: 500;
        }

        .form-floating-modern .form-control:focus {
            border-color: #8b5cf6;
            box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.2);
            outline: none;
            background-color: #fff;
        }

        .form-floating-modern label {
            position: absolute;
            left: 1.2rem;
            top: 50%;
            transform: translateY(-50%);
            background-color: transparent;
            padding: 0 0.3rem;
            font-weight: 500;
            color: #7c7f8c;
            transition: 0.2s ease all;
            pointer-events: none;
            font-size: 1rem;
        }

        /* Label floating effect */
        .form-floating-modern .form-control:focus ~ label,
        .form-floating-modern .form-control:not(:placeholder-shown) ~ label {
            top: 0px;
            transform: translateY(-50%) scale(0.85);
            background-color: white;
            left: 1rem;
            color: #7c3aed;
            font-weight: 600;
        }

        /* fix placeholder always empty to trigger floating */
        .form-floating-modern .form-control::placeholder {
            color: transparent;
        }

        /* Social & action area */
        .login-social {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin: 1.8rem 0 1rem 0;
        }

        .google-btn {
            background: #fff;
            border: 1.5px solid #eef2ff;
            border-radius: 50px;
            width: 52px;
            height: 52px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.25s;
            color: #ea4335;
            text-decoration: none;
            font-size: 1.8rem;
            box-shadow: 0 5px 12px rgba(0,0,0,0.05);
        }

        .google-btn:hover {
            background: linear-gradient(145deg, #fff, #f8f9ff);
            transform: scale(1.05);
            border-color: #ea4335;
            box-shadow: 0 8px 18px rgba(234, 67, 53, 0.2);
            color: #c5221f;
        }

        .skip-btn {
            flex: 1;
            background: #f1f5f9;
            border: none;
            font-weight: 600;
            border-radius: 50px;
            padding: 0.7rem 0;
            text-decoration: none;
            text-align: center;
            color: #334155;
            transition: all 0.25s;
            font-size: 0.95rem;
        }

        .skip-btn:hover {
            background: #e2e8f0;
            color: #0f172a;
            transform: translateY(-2px);
        }

        /* submit button: modern gradient arrow */
        .submit-btn {
            background: linear-gradient(95deg, #5a3e8f 0%, #7c3aed 100%);
            border: none;
            border-radius: 60px;
            padding: 0.85rem;
            font-size: 1.2rem;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 8px 18px rgba(124, 58, 237, 0.3);
            color: white;
        }

        .submit-btn:hover {
            background: linear-gradient(95deg, #4c2d7a, #6d28d9);
            transform: scale(1.01);
            box-shadow: 0 12px 24px rgba(124, 58, 237, 0.4);
        }

        .submit-btn i {
            font-size: 1.4rem;
            transition: transform 0.2s;
        }

        .submit-btn:hover i {
            transform: translateX(5px);
        }

        /* link group */
        .link-group {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1.3rem;
            gap: 0.5rem;
        }

        .custom-link {
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: 0.2s;
            color: #4b5563;
            padding: 0.2rem 0.3rem;
            border-radius: 20px;
        }

        .custom-link:hover {
            color: #7c3aed;
            background: #ede9fe;
            text-decoration: none;
        }

        /* Toast Notification - beautifully redesigned */
        .toast-premium {
            position: fixed;
            top: 25px;
            right: 25px;
            z-index: 1100;
            min-width: 320px;
            background: rgba(0,0,0,0.75);
            backdrop-filter: blur(10px);
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 35px -12px rgba(0,0,0,0.3);
            color: white;
        }

        .toast-premium .toast-header {
            background: rgba(255,255,255,0.15);
            border-bottom: 1px solid rgba(255,255,255,0.2);
            border-radius: 20px 20px 0 0;
            color: white;
            font-weight: 600;
            padding: 0.8rem 1.2rem;
        }

        .toast-premium .toast-header small {
            font-size: 0.9rem;
            letter-spacing: 0.3px;
            color: #ffd966;
        }

        .toast-premium .btn-close-white {
            filter: brightness(0) invert(1);
            opacity: 0.8;
        }

        .toast-premium .toast-body {
            padding: 1rem 1.2rem;
            font-size: 0.95rem;
            background: rgba(0,0,0,0.5);
            border-radius: 0 0 20px 20px;
            font-weight: 500;
            color: #f1f5f9;
        }

        /* responsiveness */
        @media (max-width: 500px) {
            .form-container {
                padding: 1.2rem 1.2rem 1.8rem;
            }
            .glass-card {
                margin: 1rem;
                border-radius: 1.5rem !important;
            }
            .login-social {
                flex-wrap: wrap;
            }
            .skip-btn {
                width: 100%;
            }
            .toast-premium {
                left: 16px;
                right: 16px;
                min-width: auto;
                top: 16px;
            }
        }

        /* subtle ripple on button */
        .ripple-effect {
            overflow: hidden;
            position: relative;
        }
    </style>
</head>
<body>
<div class="loginPage">
    <!-- Announce Toast (if condition true) -->
    {{#if announce}}
    <div aria-live="polite" aria-atomic="true" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1100;">
        <div class="toast toast-premium" id="alert" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="8000">
            <div class="toast-header toast-container-header d-flex justify-content-between align-items-center">
                <i class="bi bi-info-circle-fill me-2" style="color: #ffb347;"></i>
                <small class="fw-semibold">THÔNG BÁO HỆ THỐNG</small>
                <button type="button" class="btn-close btn-close-white btn-sm" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body toast-container-body">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> {{message}}
            </div>
        </div>
    </div>
    {{/if}}

    <div class="container w-100 d-flex align-items-center justify-content-center py-4">
        <div class="glass-card">
            <div class="form-container">
                <!-- Header with beautiful gradient text -->
                <div class="login-header text-center">
                    <h1>Đăng Nhập</h1>
                    <div class="sub">Chào mừng trở lại! 👋</div>
                    <hr class="gradient-hr">
                </div>

                <!-- Login Form (KEEP ALL FUNCTIONALITIES: action, method, id) -->
                <form id="loginForm" action="/login" method="post" novalidate>
                    <!-- Username / Email field with floating modern design -->
                    <div class="form-floating-modern">
                        <input type="email" id="username" name="username" class="form-control" placeholder=" " autocomplete="email" required>
                        <label for="username"><i class="bi bi-envelope-fill me-1" style="font-size: 0.9rem;"></i> Tên Đăng Nhập</label>
                    </div>

                    <!-- Password field -->
                    <div class="form-floating-modern">
                        <input type="password" id="password" name="password" class="form-control" placeholder=" " autocomplete="current-password" required>
                        <label for="password"><i class="bi bi-lock-fill me-1"></i> Mật Khẩu</label>
                    </div>

                    <!-- Social + skip section (structure preserved with extra beauty) -->
                    <div class="login-social">
                        <a class="google-btn" href="/auth/google" title="Đăng nhập với Google">
                            <i class="bi bi-google"></i>
                        </a>
                        <a class="skip-btn" href="/"><i class="bi bi-arrow-right-circle me-1"></i> Bỏ qua đăng nhập</a>
                    </div>

                    <!-- Submit + extra links -->
                    <div class="mt-3">
                        <button class="btn submit-btn w-100 d-flex align-items-center justify-content-center gap-2" type="submit">
                            <span>Đăng nhập ngay</span>
                            <i class="bi bi-arrow-right-circle-fill"></i>
                        </button>
                        <div class="link-group">
                            <a class="custom-link" href="/register"><i class="bi bi-person-plus-fill me-1"></i>Đăng kí tài khoản</a>
                            <a class="custom-link" href="/account/password"><i class="bi bi-question-circle-fill me-1"></i>Quên Mật Khẩu</a>
                        </div>
                    </div>
                </form>
                <!-- subtle note (optional) -->
                <div class="text-center mt-4">
                    <small class="text-muted" style="opacity: 0.7;">🔒 Bảo mật & an toàn tuyệt đối</small>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Enhanced toast with same logic but modern + auto delay set to 8000ms
    $(document).ready(function () {
        // keep original toast functionality with extra customization
        var toastEl = document.getElementById('alert');
        if (toastEl) {
            // Bootstrap 5 toast initialization with custom duration (8 secs)
            var bsToast = new bootstrap.Toast(toastEl, {
                animation: true,
                autohide: true,
                delay: 8000
            });
            bsToast.show();
            // additionally, keep the jQuery method as backup for compatibility (but both)
            $("#alert").toast ? $("#alert").toast({ animation: true, delay: 8000 }).toast("show") : null;
        }

        // Additional visual micro-interactions: add animation on form submit loading effect
        const loginForm = document.getElementById('loginForm');
        if (loginForm) {
            loginForm.addEventListener('submit', function(e) {
                const submitBtn = this.querySelector('.submit-btn');
                if (submitBtn) {
                    const originalHtml = submitBtn.innerHTML;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Đang xử lý...';
                    submitBtn.disabled = true;
                    // optional: you can re-enable after timeout if needed, but form submit will navigate
                    // we reset after 3 sec to avoid stuck if form fails (but generally not needed)
                    setTimeout(() => {
                        if (submitBtn.disabled) {
                            submitBtn.innerHTML = originalHtml;
                            submitBtn.disabled = false;
                        }
                    }, 5000);
                }
            });
        }
    });

    // add elegant placeholder behavior for floating labels (without native floating class)
    // but we use custom style, still ensure each input has placeholder attribute.
    document.querySelectorAll('.form-floating-modern .form-control').forEach(input => {
        if (!input.hasAttribute('placeholder')) {
            input.setAttribute('placeholder', ' ');
        }
        // on load trigger floating if value exists
        if (input.value !== "") {
            input.dispatchEvent(new Event('input'));
        }
    });

    // extra beauty: dynamic particle on background? subtle but keep light
    // just additional effect for nice ripple on buttons
    const createRipple = (event, element) => {
        const rect = element.getBoundingClientRect();
        const ripple = document.createElement('span');
        ripple.className = 'ripple-span';
        const diameter = Math.max(rect.width, rect.height);
        const radius = diameter / 2;
        ripple.style.width = ripple.style.height = `${diameter}px`;
        ripple.style.left = `${event.clientX - rect.left - radius}px`;
        ripple.style.top = `${event.clientY - rect.top - radius}px`;
        ripple.style.position = 'absolute';
        ripple.style.background = 'rgba(255,255,255,0.5)';
        ripple.style.borderRadius = '50%';
        ripple.style.transform = 'scale(0)';
        ripple.style.transition = 'transform 0.5s ease-out, opacity 0.5s ease';
        ripple.style.pointerEvents = 'none';
        element.style.position = 'relative';
        element.style.overflow = 'hidden';
        element.appendChild(ripple);
        setTimeout(() => {
            ripple.style.transform = 'scale(2)';
            ripple.style.opacity = '0';
        }, 10);
        setTimeout(() => ripple.remove(), 500);
    };

    document.querySelectorAll('.submit-btn, .google-btn, .skip-btn, .custom-link').forEach(btn => {
        btn.addEventListener('click', (e) => {
            if (btn.classList.contains('custom-link') || btn.classList.contains('skip-btn')) {
                // allow navigation but add ripple
                createRipple(e, btn);
            } else if (btn.classList.contains('submit-btn')) {
                createRipple(e, btn);
            } else {
                createRipple(e, btn);
            }
        });
    });
</script>

<style>
    /* additional ripple styling + animations */
    .ripple-span {
        position: absolute;
        background: rgba(255,255,255,0.6);
        border-radius: 50%;
        transform: scale(0);
        animation: rippleAnim 0.5s linear;
        pointer-events: none;
        z-index: 5;
    }
    @keyframes rippleAnim {
        to {
            transform: scale(4);
            opacity: 0;
        }
    }
    .submit-btn, .google-btn, .skip-btn {
        transition: all 0.2s;
    }
    .custom-link {
        position: relative;
        z-index: 2;
    }
    /* fix for google button icon  */
    .google-btn i {
        font-size: 1.8rem;
    }
    /* better input autofill style */
    input:-webkit-autofill,
    input:-webkit-autofill:focus {
        transition: background-color 0s 600000s, color 0s 600000s;
    }
    input:autofill {
        background-color: #fef9e3 !important;
    }
    .form-floating-modern .form-control:autofill ~ label {
        top: 0px;
        transform: translateY(-50%) scale(0.85);
        background-color: white;
    }
    /* extra hover glow on card */
    .glass-card {
        transition: all 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }
</style>
</body>
</html>