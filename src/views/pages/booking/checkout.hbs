{{!-- src/views/pages/booking/checkout.hbs --}}
<div class="checkout-page">
    <div class="container py-4" style="max-width: 1000px;">
        <h1 class="mb-4">Complete your booking</h1>
        
        <div class="row">
            <div class="col-lg-7">
                <form action="/rooms/{{room._id}}/book" method="post" class="booking-form" id="bookingForm">
                    <input type="hidden" name="checkIn" value="{{checkIn}}">
                    <input type="hidden" name="checkOut" value="{{checkOut}}">
                    <input type="hidden" name="guests" value="{{guests}}">
                    
                    <div class="card shadow-sm mb-4 border-0 rounded-4">
                        <div class="card-body p-4">
                            <h5 class="card-title mb-3">Your Information</h5>
                            
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Full Name</label>
                                <input type="text" class="form-control" value="{{user_name}}" readonly disabled>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Email Address</label>
                                <input type="email" class="form-control" value="{{user_email}}" readonly disabled>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label fw-semibold required">Phone Number</label>
                                <input type="tel" name="phoneNumber" class="form-control" required placeholder="Enter your phone number">
                                <small class="text-muted">We'll send booking confirmation via SMS</small>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card shadow-sm mb-4 border-0 rounded-4">
                        <div class="card-body p-4">
                            <h5 class="card-title mb-3">Special Requests (Optional)</h5>
                            <textarea name="specialRequests" class="form-control" rows="3" 
                                      placeholder="Any special requests? Let the host know..."></textarea>
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 py-3 fw-semibold" id="submitBtn">
                        Confirm Booking
                    </button>
                </form>
            </div>
            
            <div class="col-lg-5">
                <div class="booking-summary card shadow-sm sticky-top border-0 rounded-4" style="top: 90px;">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Booking Summary</h5>
                        
                        <div class="room-info d-flex gap-3 mb-3 pb-3 border-bottom">
                            {{#if room.images}}
                            <img src="{{room.images.[0].url}}" class="rounded-3" style="width: 70px; height: 70px; object-fit: cover;">
                            {{else}}
                            <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                                <i class="bi bi-image text-muted fs-2"></i>
                            </div>
                            {{/if}}
                            <div>
                                <h6 class="mb-1">{{room.name}}</h6>
                                <p class="text-muted small mb-0">{{room.city}}, {{room.district}}</p>
                            </div>
                        </div>
                        
                        <div class="dates mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between mb-2">
                                <span><i class="bi bi-calendar-check"></i> Check-in</span>
                                <span class="fw-semibold">{{formatDate checkIn 'MMM DD, YYYY'}}</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span><i class="bi bi-calendar-x"></i> Check-out</span>
                                <span class="fw-semibold">{{formatDate checkOut 'MMM DD, YYYY'}}</span>
                            </div>
                            <div class="d-flex justify-content-between mt-2 text-muted">
                                <span>Total nights</span>
                                <span>{{nights}} nights</span>
                            </div>
                            <div class="d-flex justify-content-between mt-1 text-muted">
                                <span>Guests</span>
                                <span>{{guests}} guest(s)</span>
                            </div>
                        </div>
                        
                        <div class="price-details">
                            <div class="d-flex justify-content-between mb-2">
                                <span>{{formatCurrency room.price}} x {{nights}} nights</span>
                                <span>{{formatCurrency subtotal}}</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Cleaning fee</span>
                                <span>{{formatCurrency cleaningFee}}</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Service fee (10%)</span>
                                <span>{{formatCurrency serviceFee}}</span>
                            </div>
                            <hr class="my-3">
                            <div class="d-flex justify-content-between fw-bold fs-5">
                                <span>Total</span>
                                <span class="text-primary">{{formatCurrency totalPrice}}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.checkout-page {
    background: #F7F7F7;
    min-height: calc(100vh - 200px);
    padding: 24px 0;
}

.form-control {
    border-radius: 12px;
    border: 1px solid #DDDDDD;
    padding: 12px;
}

.form-control:focus {
    border-color: #FF385C;
    box-shadow: 0 0 0 3px rgba(255, 56, 92, 0.1);
}

.booking-summary {
    background: white;
}

.required:after {
    content: ' *';
    color: #EA4335;
}

.btn-primary {
    background: #FF385C;
    border: none;
    border-radius: 40px;
    transition: all 0.3s ease;
}

.btn-primary:hover {
    background: #E31C5F;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 56, 92, 0.3);
}

@media (max-width: 768px) {
    .booking-summary {
        margin-top: 24px;
        position: relative !important;
        top: 0 !important;
    }
}
</style>

<script>
document.getElementById('bookingForm')?.addEventListener('submit', function(e) {
    const phoneInput = document.querySelector('input[name="phoneNumber"]');
    if (!phoneInput.value.trim()) {
        e.preventDefault();
        alert('Please enter your phone number');
        phoneInput.focus();
    }
});
</script>