{{!-- src/views/pages/booking/my-bookings.hbs --}}
<div class="my-bookings-page">
    <div class="container py-4">
        <h1 class="mb-4">My Bookings</h1>
        
        {{#if query.success}}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> {{query.success}}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        {{/if}}
        
        {{#if query.error}}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> {{query.error}}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        {{/if}}
        
        <div class="bookings-list">
            {{#each bookings}}
            <div class="booking-item card shadow-sm mb-4 border-0 rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-3">
                        <img src="{{#if this.room.images}}{{this.room.images.[0].url}}{{else}}https://placehold.co/300x200/F7F7F7/717171?text=No+Image{{/if}}" 
                             class="img-fluid rounded-start booking-image" 
                             alt="{{this.room.name}}"
                             style="height: 100%; min-height: 180px; width: 100%; object-fit: cover;">
                    </div>
                    <div class="col-md-6">
                        <div class="card-body">
                            <h5 class="card-title">{{this.room.name}}</h5>
                            <p class="card-text text-muted">
                                <i class="bi bi-geo-alt"></i> {{this.room.city}}{{#if this.room.district}}, {{this.room.district}}{{/if}}
                            </p>
                            <div class="booking-details mt-3">
                                <div class="row">
                                    <div class="col-6 mb-2">
                                        <small class="text-muted">Check-in</small>
                                        <div class="fw-semibold">{{formatDate this.checkIn 'MMM DD, YYYY'}}</div>
                                    </div>
                                    <div class="col-6 mb-2">
                                        <small class="text-muted">Check-out</small>
                                        <div class="fw-semibold">{{formatDate this.checkOut 'MMM DD, YYYY'}}</div>
                                    </div>
                                    <div class="col-6 mb-2">
                                        <small class="text-muted">Guests</small>
                                        <div class="fw-semibold">{{this.guests}} guests</div>
                                    </div>
                                    <div class="col-6 mb-2">
                                        <small class="text-muted">Total paid</small>
                                        <div class="fw-semibold text-primary">{{formatCurrency this.totalPrice}}</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 d-flex flex-column justify-content-center p-3 bg-light">
                        <div class="booking-status mb-3">
                            {{#if_eq this.status 'confirmed'}}
                            <span class="badge bg-success">Confirmed</span>
                            {{else if_eq this.status 'pending'}}
                            <span class="badge bg-warning text-dark">Pending</span>
                            {{else if_eq this.status 'cancelled'}}
                            <span class="badge bg-danger">Cancelled</span>
                            {{else if_eq this.status 'completed'}}
                            <span class="badge bg-info">Completed</span>
                            {{else}}
                            <span class="badge bg-secondary">{{this.status}}</span>
                            {{/if_eq}}
                        </div>
                        
                        <a href="/rooms/{{this.room._id}}" class="btn btn-outline-primary btn-sm mb-2">
                            <i class="bi bi-eye"></i> View Room
                        </a>
                        
                        {{#if_eq this.status 'confirmed'}}
                        <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#cancelModal{{this._id}}">
                            <i class="bi bi-x-circle"></i> Cancel Booking
                        </button>
                        {{/if_eq}}
                    </div>
                </div>
            </div>
            
            <!-- Cancel Modal -->
            {{#if_eq this.status 'confirmed'}}
            <div class="modal fade" id="cancelModal{{this._id}}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content rounded-4">
                        <div class="modal-header border-0">
                            <h5 class="modal-title">Cancel Booking</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p>Are you sure you want to cancel this booking?</p>
                            <p class="text-muted small">
                                <i class="bi bi-info-circle"></i> 
                                Cancellation is free up to 24 hours before check-in.
                            </p>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Keep Booking</button>
                            <form action="/booking/cancel/{{this._id}}" method="post" class="d-inline">
                                <button type="submit" class="btn btn-danger">Yes, Cancel</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            {{/if_eq}}
            
            {{else}}
            <div class="empty-state text-center py-5 bg-white rounded-4">
                <i class="bi bi-calendar-x display-1 text-muted"></i>
                <h3 class="mt-3">No bookings yet</h3>
                <p class="text-muted">Start exploring and book your first stay!</p>
                <a href="/" class="btn btn-primary mt-3">
                    <i class="bi bi-search"></i> Explore Homes
                </a>
            </div>
            {{/each}}
        </div>
    </div>
</div>

<style>
.my-bookings-page {
    background: #F7F7F7;
    min-height: calc(100vh - 200px);
    padding: 24px 0;
}

.booking-item {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.booking-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12) !important;
}

.badge {
    padding: 8px 16px;
    font-size: 12px;
    font-weight: 500;
    border-radius: 20px;
}

.bg-success {
    background: #34A853 !important;
}

.bg-warning {
    background: #FBBC05 !important;
    color: #222222;
}

.bg-danger {
    background: #EA4335 !important;
}

.btn-outline-primary {
    border-color: #FF385C;
    color: #FF385C;
}

.btn-outline-primary:hover {
    background: #FF385C;
    border-color: #FF385C;
}

.btn-outline-danger {
    border-color: #EA4335;
    color: #EA4335;
}

.btn-outline-danger:hover {
    background: #EA4335;
    border-color: #EA4335;
    color: white;
}

.empty-state {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.btn-primary {
    background: #FF385C;
    border: none;
    border-radius: 40px;
}

.btn-primary:hover {
    background: #E31C5F;
}

@media (max-width: 768px) {
    .booking-item .row {
        flex-direction: column;
    }
    
    .booking-image {
        height: 180px;
        object-fit: cover;
    }
    
    .booking-item .col-md-3:last-child {
        border-top: 1px solid #EAEAEA;
        flex-direction: row;
        gap: 12px;
    }
    
    .booking-status {
        margin-bottom: 0;
    }
}
</style>