{{!-- src/views/pages/host/room-create.hbs --}}
<div class="room-form-page">
    <div class="container py-4">
        <div class="form-container">
            <h1 class="form-title">Create New Room</h1>
            
            <form action="/host/rooms/create" method="post" class="room-form">
                <!-- Basic Information -->
                <div class="form-section">
                    <h2 class="section-title">Basic Information</h2>
                    
                    <div class="form-group">
                        <label class="form-label">Room Name *</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Price per night (VND) *</label>
                        <input type="number" name="price" class="form-control" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Category</label>
                        <select name="type" class="form-control">
                            <option value="">Select category</option>
                            {{#each categories}}
                            <option value="{{this._id}}">{{this.name}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
                
                <!-- Location Information -->
                <div class="form-section">
                    <h2 class="section-title">Location</h2>
                    
                    <div class="form-group">
                        <label class="form-label">Address *</label>
                        <input type="text" name="address" class="form-control" required>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">City *</label>
                                <input type="text" name="city" class="form-control" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">District</label>
                                <input type="text" name="district" class="form-control">
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Room Details -->
                <div class="form-section">
                    <h2 class="section-title">Room Details</h2>
                    
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">Max Guests</label>
                                <input type="number" name="maximuncus" class="form-control" value="2" min="1">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">Bedrooms</label>
                                <input type="number" name="bedroom" class="form-control" value="1" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">Beds</label>
                                <input type="number" name="bed" class="form-control" value="1" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label class="form-label">Bathrooms</label>
                                <input type="number" name="shower" class="form-control" value="1" min="0">
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Amenities -->
                <div class="form-section">
                    <h2 class="section-title">Amenities</h2>
                    
                    <div class="amenities-grid">
                        <label class="checkbox-label">
                            <input type="checkbox" name="wifi">
                            <span><i class="bi bi-wifi"></i> WiFi</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="air_conditioner">
                            <span><i class="bi bi-snow"></i> Air Conditioner</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="parking">
                            <span><i class="bi bi-p-square"></i> Parking</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="kitchen">
                            <span><i class="bi bi-egg-fried"></i> Kitchen</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="pool">
                            <span><i class="bi bi-water"></i> Pool</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="tv">
                            <span><i class="bi bi-tv"></i> TV</span>
                        </label>
                    </div>
                </div>
                
                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-submit">Create Room</button>
                    <a href="/host/rooms" class="btn-cancel">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.room-form-page {
    background: #F7F7F7;
    min-height: calc(100vh - 200px);
    padding: 40px 0;
}

.container {
    max-width: 800px;
    margin: 0 auto;
}

.form-container {
    background: white;
    border-radius: 24px;
    padding: 32px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.form-title {
    font-size: 28px;
    font-weight: 700;
    color: #222222;
    margin-bottom: 32px;
    text-align: center;
}

.form-section {
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid #EAEAEA;
}

.form-section:last-child {
    border-bottom: none;
}

.section-title {
    font-size: 20px;
    font-weight: 600;
    color: #222222;
    margin-bottom: 20px;
}

.form-group {
    margin-bottom: 20px;
}

.form-label {
    display: block;
    font-weight: 500;
    margin-bottom: 8px;
    color: #222222;
}

.form-control {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid #DDDDDD;
    border-radius: 12px;
    font-size: 16px;
    transition: all 0.3s ease;
}

.form-control:focus {
    outline: none;
    border-color: #FF385C;
    box-shadow: 0 0 0 3px rgba(255, 56, 92, 0.1);
}

.row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
}

.amenities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
}

.checkbox-label {
    display: flex;
    align-items: center;
    cursor: pointer;
}

.checkbox-label input {
    margin-right: 10px;
    width: 18px;
    height: 18px;
    cursor: pointer;
}

.checkbox-label span {
    font-size: 16px;
    color: #484848;
    display: flex;
    align-items: center;
    gap: 8px;
}

.form-actions {
    display: flex;
    gap: 16px;
    margin-top: 32px;
}

.btn-submit,
.btn-cancel {
    flex: 1;
    padding: 12px 24px;
    border-radius: 40px;
    font-size: 16px;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
}

.btn-submit {
    background: #FF385C;
    color: white;
    border: none;
}

.btn-submit:hover {
    background: #E31C5F;
    transform: translateY(-2px);
}

.btn-cancel {
    background: #F7F7F7;
    color: #484848;
    border: 1px solid #DDDDDD;
}

.btn-cancel:hover {
    background: #EAEAEA;
}

@media (max-width: 576px) {
    .form-container {
        padding: 20px;
    }
    
    .form-title {
        font-size: 24px;
    }
    
    .row {
        grid-template-columns: 1fr;
    }
    
    .amenities-grid {
        grid-template-columns: 1fr;
    }
}
</style>