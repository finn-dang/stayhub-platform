{{!-- src/views/pages/host/dashboard.hbs --}}
<div class="host-dashboard">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="dashboard-title">Host Dashboard</h1>
            <div class="dashboard-actions">
                <a href="/host/rooms/create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Add New Room
                </a>
            </div>
        </div>
        
        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="bi bi-building"></i>
                </div>
                <div class="stat-info">
                    <h3 class="stat-value">{{stats.totalRooms}}</h3>
                    <p class="stat-label">Total Rooms</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon success">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div class="stat-info">
                    <h3 class="stat-value">{{stats.activeRooms}}</h3>
                    <p class="stat-label">Active Rooms</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon warning">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="stat-info">
                    <h3 class="stat-value">{{stats.pendingRooms}}</h3>
                    <p class="stat-label">Pending Approval</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon info">
                    <i class="bi bi-eye"></i>
                </div>
                <div class="stat-info">
                    <h3 class="stat-value">{{stats.totalViews}}</h3>
                    <p class="stat-label">Total Views</p>
                </div>
            </div>
        </div>
        
        <!-- Recent Bookings -->
        <div class="recent-section mt-5">
            <h2 class="section-title">Recent Bookings</h2>
            <div class="bookings-table-wrapper">
                {{#if recentBookings.length}}
                <table class="bookings-table">
                    <thead>
                        <tr>
                            <th>Room</th>
                            <th>Guest</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Total</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each recentBookings}}
                        <tr>
                            <td>{{this.room.name}}</td>
                            <td>{{this.user.name}}</td>
                            <td>{{formatDate this.checkIn}}</td>
                            <td>{{formatDate this.checkOut}}</td>
                            <td>{{formatCurrency this.totalPrice}}</td>
                            <td>
                                <span class="status-badge status-{{this.status}}">
                                    {{this.status}}
                                </span>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
                {{else}}
                <div class="empty-state-small">
                    <i class="bi bi-calendar"></i>
                    <p>No bookings yet</p>
                </div>
                {{/if}}
            </div>
        </div>
        
        <!-- Quick Actions -->
        <div class="quick-actions mt-5">
            <h2 class="section-title">Quick Actions</h2>
            <div class="actions-grid">
                <a href="/host/rooms" class="action-card">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>Manage Rooms</span>
                </a>
                <a href="/host/rooms/create" class="action-card">
                    <i class="bi bi-plus-square"></i>
                    <span>Add New Room</span>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
.host-dashboard {
    background: #F7F7F7;
    min-height: calc(100vh - 200px);
}

.container {
    max-width: 1280px;
    margin: 0 auto;
}

.dashboard-title {
    font-size: 32px;
    font-weight: 700;
    color: #222222;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 40px;
}

.stat-card {
    background: white;
    border-radius: 16px;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
}

.stat-icon {
    width: 56px;
    height: 56px;
    background: #FFF5F6;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.stat-icon i {
    font-size: 28px;
    color: #FF385C;
}

.stat-icon.success {
    background: #E8F5E9;
}

.stat-icon.success i {
    color: #34A853;
}

.stat-icon.warning {
    background: #FFF3E0;
}

.stat-icon.warning i {
    color: #FBBC05;
}

.stat-icon.info {
    background: #E3F2FD;
}

.stat-icon.info i {
    color: #4285F4;
}

.stat-value {
    font-size: 28px;
    font-weight: 700;
    color: #222222;
    margin: 0 0 4px;
}

.stat-label {
    color: #717171;
    font-size: 14px;
    margin: 0;
}

.section-title {
    font-size: 20px;
    font-weight: 600;
    color: #222222;
    margin-bottom: 20px;
}

.bookings-table-wrapper {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.bookings-table {
    width: 100%;
    border-collapse: collapse;
}

.bookings-table th,
.bookings-table td {
    padding: 16px;
    text-align: left;
    border-bottom: 1px solid #EAEAEA;
}

.bookings-table th {
    background: #F7F7F7;
    font-weight: 600;
    color: #222222;
}

.bookings-table td {
    color: #484848;
}

.status-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
}

.status-pending {
    background: #FFF3E0;
    color: #FBBC05;
}

.status-confirmed {
    background: #E8F5E9;
    color: #34A853;
}

.status-completed {
    background: #E3F2FD;
    color: #4285F4;
}

.status-cancelled {
    background: #FEF2F0;
    color: #EA4335;
}

.empty-state-small {
    text-align: center;
    padding: 60px;
}

.empty-state-small i {
    font-size: 48px;
    color: #DDDDDD;
    margin-bottom: 16px;
}

.empty-state-small p {
    color: #717171;
}

.actions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
}

.action-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    text-align: center;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.action-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
}

.action-card i {
    font-size: 32px;
    color: #FF385C;
    margin-bottom: 12px;
    display: block;
}

.action-card span {
    font-size: 16px;
    font-weight: 500;
    color: #222222;
}

@media (max-width: 768px) {
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }
    
    .actions-grid {
        grid-template-columns: 1fr;
    }
    
    .bookings-table {
        font-size: 14px;
    }
    
    .bookings-table th,
    .bookings-table td {
        padding: 12px;
    }
}
</style>