<div class="home-page">
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-content">
            <h1 class="hero-title">Find your perfect stay ✨</h1>
            <p class="hero-subtitle">Discover unique homes and experience the world like never before</p>
        </div>
    </section>

    <!-- Search Bar -->
    <div class="search-container">
        <div class="search-card">
            <form action="/" method="GET" class="search-form">
                <div class="search-input-wrapper">
                    <i class="bi bi-search"></i>
                    <input type="text" 
                           name="search" 
                           placeholder="Search destinations..." 
                           value="{{query.search}}"
                           class="search-input">
                </div>
                <button type="submit" class="search-btn">Search</button>
            </form>
        </div>
    </div>

    <!-- Categories Section -->
    <section class="categories-section">
        <div class="categories-wrapper">
            <div class="category-item {{#unless query.type}}active{{/unless}}" data-category-id="all">
                <div class="category-icon">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                </div>
                <span class="category-name">All</span>
            </div>
            {{#each house_category_list}}
            <div class="category-item {{#if (eq ../query.type this._id)}}active{{/if}}" data-category-id="{{this._id}}">
                <div class="category-icon">
                    <img src="{{this.img}}" alt="{{this.name}}" loading="lazy">
                </div>
                <span class="category-name">{{this.name}}</span>
            </div>
            {{/each}}
        </div>
    </section>

    <!-- Sort & Filter Bar -->
    <section class="sort-filter-section">
        <div class="sort-filter-container">
            <div class="sort-buttons">
                <a href="?{{#if query.search}}search={{query.search}}&{{/if}}{{#if query.type}}type={{query.type}}&{{/if}}incre=true" 
                   class="sort-btn {{#if query.incre}}active{{/if}}">
                    <i class="bi bi-sort-up"></i> Price: Low to High
                </a>
                <a href="?{{#if query.search}}search={{query.search}}&{{/if}}{{#if query.type}}type={{query.type}}&{{/if}}dec=true" 
                   class="sort-btn {{#if query.dec}}active{{/if}}">
                    <i class="bi bi-sort-down"></i> Price: High to Low
                </a>
            </div>
            <button class="filter-btn" data-bs-toggle="modal" data-bs-target="#filterModal">
                <i class="bi bi-funnel"></i> Filters
            </button>
        </div>
    </section>

    <!-- Properties Grid -->
    <section class="properties-section">
        <div class="container-custom">
            {{#if sorted_house_list.length}}
            <div class="properties-grid">
                {{#each sorted_house_list}}
                <div class="property-card" data-room-id="{{this._id}}">
                    <div class="card-image-container">
                        <div id="carousel-{{@index}}" class="carousel slide card-carousel" data-bs-ride="false">
                            <div class="carousel-inner">
                                {{#each this.images}}
                                <div class="carousel-item {{#if @first}}active{{/if}}">
                                    <img src="{{this.url}}" class="card-image" alt="Property image" loading="lazy">
                                </div>
                                {{/each}}
                            </div>
                            {{#if (gt this.images.length 1)}}
                            <button class="carousel-control-prev" type="button" data-bs-target="#carousel-{{@index}}" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#carousel-{{@index}}" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            </button>
                            {{/if}}
                        </div>
                        
                        <!-- Host Avatar -->
                        <div class="host-avatar-wrapper">
                            {{#if this.host.avatar}}
                            <img src="{{this.host.avatar}}" alt="{{this.host.name}}" class="host-avatar">
                            {{else}}
                            <div class="host-avatar default-avatar">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            {{/if}}
                        </div>
                        
                        <!-- Wishlist Button -->
                        <button class="wishlist-btn" data-room-id="{{this._id}}">
                            <i class="bi bi-heart"></i>
                        </button>
                    </div>
                    
                    <div class="card-content">
                        <h3 class="property-name">{{this.name}}</h3>
                        <div class="property-location">
                            <i class="bi bi-geo-alt-fill"></i> {{this.city}}{{#if this.district}}, {{this.district}}{{/if}}
                        </div>
                        <div class="rating">
                            <div class="stars">
                                {{#times 5}}
                                    {{#if (lt this ../this.rating)}}
                                    <i class="bi bi-star-fill"></i>
                                    {{else if (eq this (floor ../this.rating))}}
                                    <i class="bi bi-star-half"></i>
                                    {{else}}
                                    <i class="bi bi-star"></i>
                                    {{/if}}
                                {{/times}}
                            </div>
                            <span class="review-count">({{this.review_count}} reviews)</span>
                        </div>
                        <div class="price">
                            {{formatCurrency this.price}} <span>/ night</span>
                        </div>
                        <a href="/rooms/{{this._id}}" class="view-details-link">View Details →</a>
                    </div>
                </div>
                {{/each}}
            </div>
            {{else}}
            <!-- Empty State -->
            <div class="empty-state">
                <i class="bi bi-house-slash"></i>
                <h3>No properties found</h3>
                <p>We couldn't find any properties matching your criteria. Try adjusting your search or filters.</p>
                <a href="/" class="empty-state-btn">Clear all filters</a>
            </div>
            {{/if}}
        </div>
    </section>
</div>

<!-- Filter Modal -->
<div class="modal fade" id="filterModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Filters</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="filterForm" method="GET" action="/">
                    <!-- Preserve existing query params -->
                    {{#if query.search}}
                    <input type="hidden" name="search" value="{{query.search}}">
                    {{/if}}
                    {{#if query.type}}
                    <input type="hidden" name="type" value="{{query.type}}">
                    {{/if}}
                    {{#if query.incre}}
                    <input type="hidden" name="incre" value="true">
                    {{/if}}
                    {{#if query.dec}}
                    <input type="hidden" name="dec" value="true">
                    {{/if}}
                    
                    <!-- Price Range -->
                    <div class="filter-group">
                        <label class="filter-label">Price Range (VND)</label>
                        <div class="price-range-inputs">
                            <input type="number" name="minPrice" class="form-control" placeholder="Min" value="{{query.minPrice}}">
                            <span>-</span>
                            <input type="number" name="maxPrice" class="form-control" placeholder="Max" value="{{query.maxPrice}}">
                        </div>
                    </div>
                    
                    <!-- Guests -->
                    <div class="filter-group">
                        <label class="filter-label">Guests</label>
                        <select name="quantity" class="form-select">
                            <option value="0">Any</option>
                            <option value="1" {{#if (eq query.quantity "1")}}selected{{/if}}>1 guest</option>
                            <option value="2" {{#if (eq query.quantity "2")}}selected{{/if}}>2 guests</option>
                            <option value="3" {{#if (eq query.quantity "3")}}selected{{/if}}>3 guests</option>
                            <option value="4" {{#if (eq query.quantity "4")}}selected{{/if}}>4 guests</option>
                            <option value="5" {{#if (eq query.quantity "5")}}selected{{/if}}>5 guests</option>
                            <option value="6" {{#if (eq query.quantity "6")}}selected{{/if}}>6+ guests</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" form="filterForm" class="btn btn-primary">Apply Filters</button>
            </div>
        </div>
    </div>
</div>

<!-- Wishlist Modal -->
<div class="modal fade" id="wishlistModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add to Wishlist</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="wishlist-modal-text">Choose a wishlist to save this property:</p>
                <div class="wishlist-options">
                    <!-- Wishlist options will be populated dynamically -->
                    <div class="text-muted text-center">Loading wishlists...</div>
                </div>
                <button class="btn btn-outline-primary w-100 mt-3" id="createNewWishlistBtn">
                    <i class="bi bi-plus-circle"></i> Create New Wishlist
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Create Wishlist Modal -->
<div class="modal fade" id="createWishlistModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create New Wishlist</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="createWishlistForm">
                    <div class="mb-3">
                        <label for="wishlistName" class="form-label">Wishlist Name</label>
                        <input type="text" class="form-control" id="wishlistName" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" form="createWishlistForm" class="btn btn-primary">Create</button>
            </div>
        </div>
    </div>
</div>

<style>
