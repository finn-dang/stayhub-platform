}

@media (max-width: 576px) {
    .categories-wrapper {
        gap: 20px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Category filter
    const categoryItems = document.querySelectorAll('.category-item');
    categoryItems.forEach(item => {
        item.addEventListener('click', function() {
            const categoryId = this.dataset.categoryId;
            const url = new URL(window.location.href);
            if (categoryId && categoryId !== 'all') {
                url.searchParams.set('type', categoryId);
            } else {
                url.searchParams.delete('type');
            }
            window.location.href = url.toString();
        });
    });
    
    // Wishlist button click
    const wishlistBtns = document.querySelectorAll('.wishlist-btn');
    wishlistBtns.forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            const roomId = this.dataset.roomId;
            
            {{#if isLoggedIn}}
            // Show wishlist modal
            const wishlistModal = new bootstrap.Modal(document.getElementById('wishlistModal'));
            // Fetch wishlists and populate modal
            fetchWishlists(roomId);
            wishlistModal.show();
            {{else}}
            if (typeof toastWarning !== 'undefined') {
                toastWarning('Please login to add to wishlist');
            } else {
                window.location.href = '/login?redirect=' + encodeURIComponent(window.location.href);
            }
            {{/if}}
        });
    });
    
    // Create wishlist
    const createBtn = document.getElementById('createNewWishlistBtn');
    if (createBtn) {
        createBtn.addEventListener('click', function() {
            bootstrap.Modal.getInstance(document.getElementById('wishlistModal')).hide();
            const createModal = new bootstrap.Modal(document.getElementById('createWishlistModal'));
            createModal.show();
        });
    }
    
    // Submit create wishlist form
    const createForm = document.getElementById('createWishlistForm');
    if (createForm) {
        createForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const name = document.getElementById('wishlistName').value;
            if (!name) return;
            
            try {
                const response = await fetch('/api/wishlist/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name })
                });
                const data = await response.json();
                if (data.success) {
                    if (typeof toastSuccess !== 'undefined') {
                        toastSuccess('Wishlist created!');
                    }
                    bootstrap.Modal.getInstance(document.getElementById('createWishlistModal')).hide();
                }
            } catch (error) {
                console.error('Error creating wishlist:', error);
            }
        });
    }
    
    // Carousel initialization - prevent card click when clicking carousel controls
    document.querySelectorAll('.carousel-control-prev, .carousel-control-next').forEach(control => {
        control.addEventListener('click', function(e) {
            e.stopPropagation();
        });
    });
    
    // Property card click
    document.querySelectorAll('.property-card').forEach(card => {
        card.addEventListener('click', function(e) {
            if (!e.target.closest('.carousel-control-prev') && 
                !e.target.closest('.carousel-control-next') &&
                !e.target.closest('.wishlist-btn')) {
                const roomId = this.dataset.roomId;
                if (roomId) {
                    window.location.href = `/rooms/${roomId}`;
                }
            }
        });
    });
});

async function fetchWishlists(roomId) {
    try {
        const response = await fetch('/api/wishlist/list');
        const wishlists = await response.json();
        const container = document.querySelector('.wishlist-options');
        
        if (wishlists.length === 0) {
            container.innerHTML = '<div class="text-muted text-center">No wishlists yet. Create one to get started!</div>';
            return;
        }
        
        container.innerHTML = wishlists.map(wishlist => `
            <div class="wishlist-option">
                <input type="radio" name="wishlistId" id="wishlist_${wishlist._id}" value="${wishlist._id}">
                <label for="wishlist_${wishlist._id}">
                    <i class="bi bi-heart"></i> ${wishlist.name}
                </label>
            </div>
        `).join('');
        
        // Add save button
        const saveBtn = document.createElement('button');
        saveBtn.className = 'btn btn-primary w-100 mt-3';
        saveBtn.textContent = 'Save';
        saveBtn.onclick = () => saveToWishlist(roomId);
        container.appendChild(saveBtn);
    } catch (error) {
        console.error('Error fetching wishlists:', error);
    }
}

async function saveToWishlist(roomId) {
    const selectedWishlist = document.querySelector('input[name="wishlistId"]:checked');
    if (!selectedWishlist) {
        if (typeof toastWarning !== 'undefined') {
            toastWarning('Please select a wishlist');
        }
        return;
    }
    
    try {
        const response = await fetch('/api/wishlist/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ wishlistId: selectedWishlist.value, roomId })
        });
        const data = await response.json();
        if (data.success) {
            if (typeof toastSuccess !== 'undefined') {
                toastSuccess('Added to wishlist!');
            }
            bootstrap.Modal.getInstance(document.getElementById('wishlistModal')).hide();
        }
    } catch (error) {
        console.error('Error saving to wishlist:', error);
    }
}
</script>