{{!-- src/views/pages/errors/500.hbs (UPDATED for consistency) --}}
<div class="error-page">
    <div class="error-container">
        <div class="error-icon">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <div class="error-code">500</div>
        <h1 class="error-title">Server Error</h1>
        <p class="error-message">
            Something went wrong on our end. Please try again later.
        </p>
        
        {{#if error}}
        <div class="error-details">
            <p class="error-detail-text">{{error}}</p>
        </div>
        {{/if}}
        
        <div class="error-actions">
            <a href="javascript:location.reload()" class="error-btn secondary">
                <i class="bi bi-arrow-repeat"></i> Try Again
            </a>
            <a href="/" class="error-btn primary">
                <i class="bi bi-house-heart-fill"></i> Back to Home
            </a>
        </div>
    </div>
</div>

<style>
